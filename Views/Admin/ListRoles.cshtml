@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "ListRoles";
}

<div class="container mt-4">
    <h2>Role Management</h2>
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            Create New Role
        </div>
        <div class="card-body">
            <form asp-action="CreateRole" method="post" class="row g-3">
                <div class="col-auto">
                    <input type="text" name="roleName" class="form-control" placeholder="Enter role" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-success">Create Role</button>
                </div>
            </form>
        </div>
    </div>
    <div class="card">
        <div class="card-header bg-dark text-white">
            Existing Roles
        </div>
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Role Id</th>
                        <th>Role Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>
                                    <form method="post" asp-action="DeleteRole" asp-route-id="@item.Id" onsubmit="return confirm('Are you sure to delete the @item.Name')">
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }

                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">No roles found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
