@model List<AcademicDetail>
<table id="ExTable" class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Degree Name</th>
            <th>CGPA</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>
                    <input type="text" name="AcademicDetails[@i].DegreeName" class="form-control" value="@Model[i].DegreeName" />
                </td>
                <td>
                    <input type="text" name="AcademicDetails[@i].CGPA" class="form-control" value="@Model[i].CGPA" />
                </td>
                <td>
                    <button onclick="DeleteItem(this)" class="btn btn-danger" type="button">Remove</button>
                </td>
            </tr>
        }
    </tbody>
</table>
<input type="hidden" id="HIndex" value="@Model.Count" />
